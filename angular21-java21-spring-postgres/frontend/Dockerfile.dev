# ─── Frontend – Development ───────────────────────────────────────────────────
# Hot-reload via ng serve. Le code source est monté en volume depuis l'hôte.
# Le flag --poll est nécessaire pour que le file-watcher fonctionne correctement
# sous WSL2 et dans les volumes Docker.
# ──────────────────────────────────────────────────────────────────────────────
FROM node:22-alpine

WORKDIR /app

# Installation globale de l'Angular CLI
RUN npm install -g @angular/cli@21

# Copie des manifestes de dépendances en premier pour profiter du cache Docker.
# Le reste du code source est monté en volume (voir compose.dev.yml).
COPY package*.json ./
RUN npm install

EXPOSE 4200

# --host 0.0.0.0  : rend le serveur accessible depuis l'extérieur du conteneur
# --poll 2000     : file-watching par polling (obligatoire sous WSL2/Docker volumes)
CMD ["ng", "serve", "--host", "0.0.0.0", "--poll", "2000"]
